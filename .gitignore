# ============================================================
# Haryana Revenue Toolkit (HRTK)
# .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Compiled extensions
*.so
*.dll

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------
# IDEs
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# Pytest
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# ------------------------------------------------------------
# Static Analysis
# ------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/

# ------------------------------------------------------------
# Build Artifacts
# ------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ------------------------------------------------------------
# Packaging
# ------------------------------------------------------------
*.spec

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Runtime Workspace
# ------------------------------------------------------------
workspace/

# ------------------------------------------------------------
# SQLite Databases
# (Uncomment if databases are generated locally)
# ------------------------------------------------------------
# *.db
# *.sqlite3

# ------------------------------------------------------------
# Qt Generated Files
# ------------------------------------------------------------
*.qm
*.qrc.depends

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Operating System
# ------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store

# ------------------------------------------------------------
# Git Merge / Patch
# ------------------------------------------------------------
*.orig
*.rej